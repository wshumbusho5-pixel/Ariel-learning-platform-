# App Settings
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=ariel-secret-key-change-this-in-production-12345

# CORS - Allow frontend to connect
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:19006"]'

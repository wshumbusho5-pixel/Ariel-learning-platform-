{
  "expo": {
    "name": "Ariel",
    "slug": "ariel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ariel.learning",
      "newArchEnabled": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Ariel needs camera access to take profile pictures and create study content.",
        "NSPhotoLibraryUsageDescription": "Ariel needs photo library access to upload profile pictures and study materials.",
        "NSMicrophoneUsageDescription": "Ariel needs microphone access for live study sessions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.ariel.learning",
      "newArchEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "ariel",
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      "expo-av",
      [
        "expo-notifications",
        {
          "color": "#7c3aed"
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
